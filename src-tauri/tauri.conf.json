{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agender",
  "version": "1.8.0",
  "identifier": "com.etapa.agender",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agender",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/backend/": "backend/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2NEEyOEJBQkQ5REQxMTYKUldRVzBaMjl1aWhLOW9DRjFMeUpqN3UxVEh5aExTb3FpRythV2pGbzRzL3lWYWNkNzdrby85QkYK",
      "endpoints": [
        "https://github.com/Jonnathan-Landi/Agender/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
