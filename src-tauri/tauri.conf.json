{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agender",
  "version": "1.2.0",
  "identifier": "com.etapa.agender",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agender",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/backend/": "backend/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxMzFGMDIwN0JFQTk5RjAKUldUd21lcDdJUEF4TVFyQ3dhUnVkWGYwcWRrTXlVSHg4V095Zy9jTGZmRzRSUUtaWnB2OUtFMG4K",
      "endpoints": [
        "https://github.com/Jonnathan-Landi/Agender/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
